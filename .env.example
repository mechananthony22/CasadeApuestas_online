# ==============================================================================
# FAIRBET LAB - CONFIGURACIÓN DE VARIABLES DE ENTORNO (EJEMPLO)
# ==============================================================================

# --- CONFIGURACIÓN GENERAL DE DJANGO ---
DJANGO_SECRET_KEY=django-insecure-your-super-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- BASE DE DATOS POSTGRESQL ---
DB_NAME=fairbet
DB_USER=postgres
DB_PASSWORD=postgres_secure_password_123
DB_PORT=5432

# --- REDIS & CELERY ---
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- INTEGRACIÓN CON API-FOOTBALL ---
# Regístrate en https://dashboard.api-football.com/ para obtener una API Key
API_FOOTBALL_KEY=tu_api_key_aqui
# URL Base de la API (para suscripción directa: https://v3.football.api-sports.io o a través de RapidAPI: https://api-football-v1.p.rapidapi.com)
API_FOOTBALL_URL=https://v3.football.api-sports.io

# --- CONFIGURACIÓN JUEGO RESPONSABLE (LÍMITES GENERALES) ---
MAX_DAILY_DEPOSIT_LIMIT=1000.0000
MAX_WEEKLY_DEPOSIT_LIMIT=5000.0000
MAX_MONTHLY_DEPOSIT_LIMIT=20000.0000

# --- PROVEEDOR DE DATOS DEPORTIVOS ---
SPORTS_API_PROVIDER=the_odds_api

# --- INTEGRACIÓN CON THE ODDS API (V4) ---
# Regístrate en https://the-odds-api.com/ para obtener una API Key gratis (500 créditos/mes)
THE_ODDS_API_KEY=tu_api_key_aqui
THE_ODDS_API_URL=https://api.the-odds-api.com/v4
