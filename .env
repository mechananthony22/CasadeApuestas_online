# ==============================================================================
# FAIRBET LAB - CONFIGURACIÓN DE VARIABLES DE ENTORNO (DESARROLLO LOCAL)
# ==============================================================================

# --- CONFIGURACIÓN GENERAL DE DJANGO ---
DJANGO_SECRET_KEY=django-insecure-fairbet-lab-super-secret-development-key-2026
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- BASE DE DATOS POSTGRESQL ---
DB_NAME=fairbet
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432

# --- REDIS & CELERY ---
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- INTEGRACIÓN CON API-FOOTBALL ---
# Reemplaza con tu API Key real de api-football.com para pruebas en vivo
API_FOOTBALL_KEY=4211147a6b60ccc25bf4dad0659a59e4
API_FOOTBALL_URL=https://v3.football.api-sports.io

# --- CONFIGURACIÓN JUEGO RESPONSABLE (LÍMITES GENERALES EN FICHAS VIRTUALES) ---
MAX_DAILY_DEPOSIT_LIMIT=1000.0000
MAX_WEEKLY_DEPOSIT_LIMIT=5000.0000
MAX_MONTHLY_DEPOSIT_LIMIT=20000.0000

# --- MODO DE EJECUCIÓN ---
USE_SQLITE=True

# --- PROVEEDOR DE DATOS DEPORTIVOS ---
SPORTS_API_PROVIDER=the_odds_api

# --- INTEGRACIÓN CON THE ODDS API (V4) ---
THE_ODDS_API_KEY=e124a42500e577fecdae10d358b97c5d
THE_ODDS_API_URL=https://api.the-odds-api.com/v4
